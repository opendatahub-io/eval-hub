# EvalHub MCP Test Suite Configuration
# Copy to test.env and fill in values before running tests.

# --- Server binary ---
EVALHUB_MCP_BIN="bin/evalhub-mcp"

# --- EvalHub backend ---
EVALHUB_BASE_URL="http://localhost:8080"
EVALHUB_TOKEN="token"
EVALHUB_TENANT="tenant"

# --- HTTP transport settings ---
EVALHUB_HTTP_HOST="localhost"
EVALHUB_HTTP_PORT="3001"

# --- Test data (IDs must exist in the backend) ---
TEST_BENCHMARK_ID="bench-001"
TEST_COLLECTION_ID="coll-001"
TEST_PROVIDER_ID="prov-001"
TEST_JOB_ID="job-001"
TEST_MODEL_ENDPOINT="http://model.example.com/v1/chat"
TEST_MODEL_NAME="integration-test-model"
TEST_BENCHMARK_LABEL="rag"

# --- Invalid values for error tests ---
INVALID_TOKEN="invalid-token-value"
UNREACHABLE_URL="http://192.0.2.1:9999"

# --- Timeouts (seconds) ---
STDIO_TIMEOUT=10
HTTP_TIMEOUT=10
SERVER_STARTUP_WAIT=3
