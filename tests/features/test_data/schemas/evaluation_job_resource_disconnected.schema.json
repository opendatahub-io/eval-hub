{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eval-hub.github.io/schemas/evaluation_job_resource_disconnected.schema.json",
  "title": "EvaluationJobResource (disconnected)",
  "description": "POST /api/v1/evaluations/jobs response (EvaluationJobResource). Wraps evaluation job config fields with resource/status/results envelope.",
  "type": "object",
  "required": [
    "resource",
    "status",
    "name",
    "model",
    "benchmarks"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Evaluation job name."
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable description."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[^,|]+$"
      },
      "uniqueItems": true,
      "description": "Tags for categorizing the job (no comma or pipe characters)."
    },
    "model": {
      "$ref": "#/$defs/ModelRef"
    },
    "benchmarks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/EvaluationBenchmarkConfig"
      },
      "description": "Benchmarks to run. Mutually exclusive with collection."
    },
    "pass_criteria": {
      "$ref": "#/$defs/PassCriteria"
    },
    "experiment": {
      "$ref": "#/$defs/ExperimentConfig"
    },
    "exports": {
      "$ref": "#/$defs/EvaluationExports"
    },
    "queue": {
      "$ref": "#/$defs/QueueConfig"
    },
    "custom": {
      "type": "object",
      "additionalProperties": true
    },
    "resource": {
      "type": "object",
      "required": [
        "id",
        "tenant"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tenant": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "mlflow_experiment_id": {
          "type": "string"
        }
      }
    },
    "status": {
      "type": "object",
      "required": [
        "state",
        "message"
      ],
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "string"
        },
        "message": {
          "type": "object",
          "required": [
            "message",
            "message_code"
          ],
          "additionalProperties": false,
          "properties": {
            "message": {
              "type": "string"
            },
            "message_code": {
              "type": "string"
            }
          }
        },
        "benchmarks": {
          "type": "array"
        }
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": true,
      "description": "Results section; may be empty on job creation."
    }
  },
  "$defs": {
    "ModelRef": {
      "type": "object",
      "required": [
        "url",
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "minLength": 1,
          "description": "Model inference endpoint URL."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the model."
        },
        "auth": {
          "$ref": "#/$defs/ModelAuth"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true,
          "description": "Model-specific parameters."
        }
      }
    },
    "ModelAuth": {
      "type": "object",
      "required": [
        "secret_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "secret_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Kubernetes Secret name for model authentication credentials."
        }
      }
    },
    "EvaluationBenchmarkConfig": {
      "type": "object",
      "required": [
        "id",
        "provider_id",
        "test_data_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Benchmark identifier."
        },
        "provider_id": {
          "type": "string",
          "minLength": 1,
          "description": "Evaluation provider ID."
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "description": "Relative weight of this benchmark."
        },
        "primary_score": {
          "$ref": "#/$defs/PrimaryScore"
        },
        "pass_criteria": {
          "$ref": "#/$defs/PassCriteria"
        },
        "parameters": {
          "type": "object",
          "properties": {
            "tokenizer": {
              "type": "string",
              "const": "/test_data/tokenizer",
              "description": "Tokenizer to use for the benchmark."
            }
          },
          "additionalProperties": true,
          "description": "Provider-specific benchmark parameters."
        },
        "test_data_ref": {
          "$ref": "#/$defs/TestDataRef"
        }
      }
    },
    "PrimaryScore": {
      "type": "object",
      "required": [
        "metric"
      ],
      "additionalProperties": false,
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "lower_is_better": {
          "type": "boolean"
        }
      }
    },
    "PassCriteria": {
      "type": "object",
      "required": [
        "threshold"
      ],
      "additionalProperties": false,
      "properties": {
        "threshold": {
          "type": "number",
          "description": "Pass/fail threshold for the primary score."
        }
      }
    },
    "TestDataRef": {
      "type": "object",
      "required": [
        "s3"
      ],
      "additionalProperties": false,
      "properties": {
        "s3": {
          "$ref": "#/$defs/S3TestDataRef"
        }
      },
      "description": "External test data for Kubernetes Job runs (init container downloads to /test_data)."
    },
    "S3TestDataRef": {
      "type": "object",
      "required": [
        "bucket",
        "key",
        "secret_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1,
          "description": "S3 bucket name."
        },
        "key": {
          "type": "string",
          "minLength": 1,
          "description": "Object key or prefix within the bucket."
        },
        "secret_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Kubernetes Secret name with AWS/S3 credentials."
        }
      }
    },
    "ExperimentConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "MLflow experiment name."
        },
        "tags": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/ExperimentTag"
          }
        },
        "artifact_location": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ExperimentTag": {
      "type": "object",
      "required": [
        "key",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 250
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000
        }
      }
    },
    "EvaluationExports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oci": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "QueueConfig": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "kueue"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9._-]*[a-zA-Z0-9])?$"
        }
      }
    }
  },
  "examples": [
    {
      "name": "test-evaluation-job",
      "tags": [
        "environment"
      ],
      "model": {
        "name": "test",
        "url": "http://test.com"
      },
      "benchmarks": [
        {
          "id": "arc_easy",
          "provider_id": "lm_evaluation_harness",
          "parameters": {
            "limit": 5,
            "num_examples": 10,
            "num_fewshot": 3,
            "tokenizer": "/test_data/tokenizer"
          },
          "test_data_ref": {
            "s3": {
              "bucket": "mlpipeline",
              "key": "offline",
              "secret_ref": "minio-test"
            }
          }
        }
      ]
    }
  ]
}
