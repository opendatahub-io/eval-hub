            "primary_score": {
                "metric": "acc"
            },
            "pass_criteria": {
                "threshold": 0.5
            },
            "agent": {
                "result_interpretation": "Accuracy from 0-1; higher is better for domain tasks",
                "score_ranges": [
                    {
                        "range": "0.0-0.5",
                        "meaning": "Below acceptable threshold"
                    },
                    {
                        "range": "0.5-0.75",
                        "meaning": "Meets minimum requirements"
                    },
                    {
                        "range": "0.75-1.0",
                        "meaning": "Excellent domain alignment"
                    }
                ]
            }
        }
    ]
