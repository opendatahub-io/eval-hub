{
    "name": "my-custom-evaluator",
    "title": "Custom Internal Evaluator",
    "description": "Internal evaluation adapter for domain-specific benchmarks",
    "tags": [
        "custom",
        "internal"
    ],
    "agent": {
        "evaluates": [
            "accuracy",
            "reasoning",
            "custom-metrics"
        ],
        "recommended_when": [
            "User wants to test domain-specific models",
            "User needs custom evaluation metrics"
        ],
        "target_type": "model",
        "summary": "Custom evaluator for internal domain-specific benchmarks",
        "complements": [
            "lm_evaluation_harness"
        ],
        "hints": [
            "Requires custom dataset configuration",
            "Best used for specialized model validation"
        ],
        "result_interpretation": [
            "Higher accuracy indicates better domain alignment",
            "Scores above 0.5 meet minimum quality threshold"
        ]
    },
    "benchmarks": [
        {
            "id": "custom_domain_test",
            "name": "Domain-Specific Test",
            "description": "Custom benchmark for internal domain testing",
            "category": "reasoning",
            "metrics": [
                "acc",
                "f1"
            ],
            "num_few_shot": 0,
            "dataset_size": 1000,
            "tags": [
                "custom",
                "domain"
